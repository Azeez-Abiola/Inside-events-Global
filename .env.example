# ── Required for Vercel (build + runtime) ──────────────────────
# Add ALL of these in Vercel → Project → Settings → Environment Variables.
# Scope: Production + Preview. VITE_* must also be present at BUILD time (redeploy after adding).
#
# Client bundle (VITE_ prefix — baked in at build)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
VITE_SUPABASE_PROJECT_ID=your-project-ref

# Server-side SSR + server functions (runtime — no VITE_ prefix)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Optional (enable when you wire these features) ───────────────
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# PAYSTACK_SECRET_KEY=
# LOVABLE_API_KEY=
# LOVABLE_SEND_URL=
