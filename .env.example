# ── Required for Vercel (build + runtime) ──────────────────────
# Add ALL of these in Vercel → Project → Settings → Environment Variables.
# Scope: Production + Preview. VITE_* must also be present at BUILD time (redeploy after adding).
#
# Minimum for public pages (landing, marketplace) to load:
#   VITE_SUPABASE_URL, VITE_SUPABASE_PUBLISHABLE_KEY
#
# Full app (auth, messaging, admin, emails) also needs at runtime:
#   SUPABASE_URL, SUPABASE_PUBLISHABLE_KEY, SUPABASE_SERVICE_ROLE_KEY
#
# Client bundle (VITE_ prefix — baked in at build)
VITE_SITE_URL=https://www.insideglobalevents.com
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
VITE_SUPABASE_PROJECT_ID=your-project-ref

# Set to true only for local dev when testing the public marketplace
# VITE_MARKETPLACE_PUBLIC=true

# Server-side SSR + server functions (runtime — no VITE_ prefix)
SITE_URL=https://www.insideglobalevents.com
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Email (Resend) ─────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL="Inside Global Events <noreply@notify.www.insideglobalevents.com>"
# From Supabase Dashboard → Auth → Hooks → Send Email (generate secret there)
SEND_EMAIL_HOOK_SECRET=v1,whsec_your_hook_secret

# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# PAYSTACK_SECRET_KEY=
